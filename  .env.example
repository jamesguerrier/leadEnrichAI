# LEADENRICH AI - ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in the values.

# --- MONGODB ---
# Your MongoDB Atlas connection string.
# Ensure your cluster's IP Access List allows connections from 0.0.0.0/0 for Vercel.
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname

# --- SECURITY ---
# Secret for high-performance JWT signing.
# Generate one with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here

# --- GOOGLE AI ---
# Your Gemini API Key for lead enrichment.
# Get one at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# --- APP ---
# The canonical URL for your application (without trailing slash).
# On local: http://localhost:3000
# On Vercel: https://your-app-name.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
